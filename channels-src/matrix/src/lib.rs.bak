const SYNC_TOKEN_PATH: &str = "state/sync_token";

/// Workspace path for storing user ID.
const USER_ID_PATH: &str = "state/user_id";

/// Workspace path for storing display name.
const DISPLAY_NAME_PATH: &str = "state/display_name";

/// Workspace path for storing DM rooms.
const DM_ROOMS_PATH: &str = "state/dm_rooms";

/// Workspace path for storing DM policy.
const DM_POLICY_PATH: &str = "state/dm_policy";

/// Workspace path for storing allow_from.
const ALLOW_FROM_PATH: &str = "state/allow_from";

/// Workspace path for storing respond_to_all_group_messages flag.
const RESPOND_TO_ALL_GROUP_PATH: &str = "state/respond_to_all_group_messages";

/// Workspace path for storing group policy.
const GROUP_POLICY_PATH: &str = "state/group_policy";

/// Workspace path for storing groups.
const GROUPS_PATH: &str = "state/groups";

/// Workspace path for storing auto_join policy.
const AUTO_JOIN_PATH: &str = "state/auto_join";

/// Channel name for pairing store.
const CHANNEL_NAME: &str = "matrix";

// ============================================================================
// Utility Functions
// ============================================================================

/// Convert markdown to HTML.
///
/// Returns None if no markdown formatting is detected (plain text).
fn markdown_to_html(markdown: &str) -> Option<String> {
    let mut html = String::new();
    let mut i = 0;
    let mut in_code_block = false;
    let mut in_line_code = false;

    while i < markdown.len() {
        // Check for code block (```code```)
        if markdown[i..].starts_with("```") && !in_line_code {
            in_code_block = !in_code_block;
            if in_code_block {
                html.push_str("<pre><code>");
            } else {
                html.push_str("</code></pre>");
            }
            i += 3;
            continue;
        }

        // Check for inline code (backtick)
        if markdown[i..].starts_with('`') && !in_code_block {
            in_line_code = !in_line_code;
            if in_line_code {
                html.push_str("<code>");
            } else {
                html.push_str("</code>");
            }
            i += 1;
            continue;
        }

        // Check for bold (**bold**)
        if markdown[i..].starts_with("**") {
            html.push_str("<strong>");
            i += 2;
            let start = i;
            while i < markdown.len() && !markdown[i..].starts_with("**") {
                i += 1;
            }
            if i < markdown.len() {
                html.push_str(&markdown[start..i]);
                html.push_str("</strong>");
                i += 2;
            }
            continue;
        }

        // Check for italic (*italic*)
        if markdown[i..].starts_with("*") {
            html.push_str("<em>");
            i += 1;
            let start = i;
            while i < markdown.len() && !markdown[i..].starts_with("*") {
                i += 1;
            }
            if i < markdown.len() {
                html.push_str(&markdown[start..i]);
                html.push_str("</em>");
                i += 1;
            }
            continue;
        }

        // Check for link ([text](url))
        if markdown[i..].starts_with('[') {
            let start = i;
            while i < markdown.len() && markdown.as_bytes()[i] != b']' {
                i += 1;
            }
            if i < markdown.len() && markdown.as_bytes()[i] == b']' {
                i += 1;
                if i < markdown.len() && markdown.as_bytes()[i] == b'(' {
                    i += 1;
                    let url_start = i;
                    while i < markdown.len() && markdown.as_bytes()[i] != b')' {
                        i += 1;
                    }
                    if i < markdown.len() && markdown.as_bytes()[i] == b')' {
                        let text = &markdown[start + 1..i];
                        let url = &markdown[url_start..i];
                        html.push_str(&format!("<a href=\"{}\">{}</a>", url, text));
                        i += 1;
                    }
                }
            }
            continue;
        }

        // Handle newlines
        if markdown.as_bytes()[i] == b'\n' {
            html.push_str("<br>");
            i += 1;
            continue;
        }

        html.push(markdown.chars().nth(i).unwrap());
        i += 1;
    }

    // Check if we have any formatting
    let has_formatting = html.contains("<strong>")
        || html.contains("<em>")
        || html.contains("<code>")
        || html.contains("<pre>")
        || html.contains("<a href=");

    if has_formatting {
        Some(html)
    } else {
        None
    }
}

/// Clean mention text by stripping leading bot mentions.
fn clean_mention_text(text: &str, display_name: Option<&str>, user_id: &str) -> String {
    let mut result = text.to_string();

    // Strip display name mention (case-insensitive)
    if let Some(name) = display_name {
        let name_lower = name.to_lowercase();
        if let Some(pos) = result.to_lowercase().find(&name_lower) {
            // Remove the mention and following whitespace
            let start = pos;
            let end = pos + name_lower.len();
            result = result[start..].trim_start().to_string();
        }
    }

    // Strip user ID mention (case-insensitive)
    let user_id_lower = user_id.to_lowercase();
    if let Some(pos) = result.to_lowercase().find(&user_id_lower) {
        result = result[pos..].trim_start().to_string();
    }

    result.trim().to_string()
}

/// Check if a room is a direct message.
fn is_dm_room(room_id: &str) -> bool {
    // Check for m.direct account data
    // For now, use heuristic: room with exactly 2 members is likely a DM
    true
}

/// Create a JSON response.
fn json_response(body: String, code: u16) -> OutgoingHttpResponse {
    OutgoingHttpResponse {
        status: code,
        headers_json: "{\"Content-Type\":\"application/json\"}",
        body: body.into_bytes(),
    }
}

/// Build sync URL.
fn build_sync_url(homeserver: &str, token: Option<&str>, timeout: u64) -> String {
    let mut url = format!("{}/_matrix/client/v3/sync?timeout={}", homeserver, timeout);
    if let Some(t) = token {
        url.push_str(&format!("&since={}", t));
    }
    url
}

/// Generate unique transaction ID.
fn generate_txn_id() -> String {
    format!("{}.{}", chrono::Utc::now().timestamp_millis(), rand::random::<u16>())
}

// ============================================================================
// WIT Callback Implementations
// ============================================================================

/// Handle channel start.
fn on_start(config_json: String) -> Result<ChannelConfig, String> {
    channel_host::log(
        channel_host::LogLevel::Info,
        "Matrix channel starting",
    );

    // Parse config
    let config: MatrixConfig = serde_json::from_str(&config_json)
        .map_err(|e| format!("Failed to parse config: {}", e))?;

    // Validate homeserver
    if config.homeserver.is_empty() {
        channel_host::log(channel_host::LogLevel::Error, "Homeserver is required");
        return Err("Homeserver is required".to_string());
    }

    // Persist policies to workspace
    let _ = channel_host::workspace_write(
        format!("{}/{}", WORKSPACE_PREFIX, DM_POLICY_PATH),
        &config.dm_policy,
    );

    let _ = channel_host::workspace_write(
        format!("{}/{}", WORKSPACE_PREFIX, RESPOND_TO_ALL_GROUP_PATH),
        &config.respond_to_all_group_messages.to_string(),
    );

    let _ = channel_host::workspace_write(
        format!("{}/{}", WORKSPACE_PREFIX, GROUP_POLICY_PATH),
        &config.group_policy,
    );

    // Return channel config
    Ok(ChannelConfig {
        display_name: "Matrix".to_string(),
        http_endpoints: vec![],
        poll: Some(PollConfig {
            interval_ms: 1000,
            enabled: true,
        }),
    })
}

    // Validate homeserver
    if config.homeserver.is_empty() {
        log(log - level::error, "Homeserver is required");
        return AgentResponse::Err("Homeserver is required".to_string());
    }

    // Persist policies to workspace
    if let Err(e) = workspace_write(
        format!("{}/{}", WORKSPACE_PREFIX, DM_POLICY_PATH),
        config.dm_policy.clone(),
    ) {
        log(
            log - level::error,
            format!("Failed to write DM policy: {}", e),
        );
    }

    if let Err(e) = workspace_write(
        format!("{}/{}", WORKSPACE_PREFIX, RESPOND_TO_ALL_GROUP_PATH),
        format!("{}", config.respond_to_all_group_messages),
    ) {
        log(
            log - level::error,
            format!("Failed to write respond_to_all_group_messages: {}", e),
        );
    }

    if let Err(e) = workspace_write(
        format!("{}/{}", WORKSPACE_PREFIX, GROUP_POLICY_PATH),
        config.group_policy.clone(),
    ) {
        log(
            log - level::error,
            format!("Failed to write group policy: {}", e),
        );
    }

    // Return channel config
    let channel_config = ChannelConfig {
        display_name: "Matrix".to_string(),
        http_endpoints: vec![],
        poll: Some(PollConfig {
            interval_ms: 1000,
            enabled: true,
        }),
    };

    AgentResponse::Ok(serde_json::to_string(&channel_config).unwrap())
}

/// Handle channel poll (sync).
fn on_poll(config_json: String, _cursor: Option<String>) {
    channel_host::log(
        channel_host::LogLevel::Debug,
        "Matrix channel polling",
    );

    // Parse config
    let config: MatrixConfig = match serde_json::from_str(&config_json) {
        Ok(c) => c,
        Err(e) => {
            channel_host::log(
                channel_host::LogLevel::Error,
                &format!("Failed to parse config: {}", e),
            );
            return;
        }
    };

    // Read homeserver from config
    let homeserver = &config.homeserver;

    // Read sync token from workspace
    let sync_token = match channel_host::workspace_read(format!("{}/{}", WORKSPACE_PREFIX, SYNC_TOKEN_PATH)) {
        Some(token) => Some(token),
        None => {
            channel_host::log(channel_host::LogLevel::Info, "No sync token found, performing first poll");
            // Call whoami to get user ID
            if let Err(e) = fetch_user_info(homeserver, &config) {
                channel_host::log(
                    channel_host::LogLevel::Error,
                    &format!("Failed to fetch user info: {}", e),
                );
                return;
            }
            None
        }
    };

    // Build sync URL
    let url = build_sync_url(homeserver, sync_token.as_deref(), 30000);

    // Prepare HTTP request headers
    let headers = "{\"Authorization\":\"Bearer matrix_access_token\"}";

    // Make HTTP request
    let response = match channel_host::http_request(
        "GET",
        &url,
        headers,
        None,
        Some(35000),
    ) {
        Ok(r) => r,
        Err(e) => {
            channel_host::log(
                channel_host::LogLevel::Error,
                &format!("HTTP request failed: {}", e),
            );
            return;
        }
    };

    // Check response status
    if response.status != 200 {
        channel_host::log(
            channel_host::LogLevel::Error,
            &format!("Sync request failed with status: {}", response.status),
        );
        return;
    }

    // Parse sync response
    let sync_response: SyncResponse = match serde_json::from_slice(&response.body) {
        Ok(r) => r,
        Err(e) => {
            channel_host::log(
                channel_host::LogLevel::Error,
                &format!("Failed to parse sync response: {}", e),
            );
            return;
        }
    };

    // Persist sync token
    let _ = channel_host::workspace_write(
        format!("{}/{}", WORKSPACE_PREFIX, SYNC_TOKEN_PATH),
        &sync_response.next_batch,
    );

    // Process messages
    for (room_id, joined_room) in &sync_response.rooms.joined {
        channel_host::log(
            channel_host::LogLevel::Debug,
            &format!("Processing room: {}", room_id),
        );

        for event in &joined_room.timeline.events {
            // Only process m.room.message events with m.text content
            if let EventContent::Message { msgtype, body, formatted_body, .. } = &event.content {
                if msgtype != "m.text" {
                    continue;
                }

                // Skip own messages
                if let Some(own_id) = &config.user_id {
                    if event.sender == *own_id {
                        continue;
                    }
                }

                // Determine if DM
                let is_direct = is_dm_room(room_id);

                // Build message metadata
                let metadata = MatrixMessageMetadata {
                    room_id: room_id.clone(),
                    event_id: event.event_id.clone(),
                    sender: event.sender.clone(),
                    is_direct,
                    thread_root_event_id: None,
                    reply_to_event_id: None,
                };

                // Serialize metadata
                let metadata_json = match serde_json::to_string(&metadata) {
                    Ok(j) => j,
                    Err(e) => {
                        channel_host::log(
                            channel_host::LogLevel::Error,
                            &format!("Failed to serialize metadata: {}", e),
                        );
                        continue;
                    }
                };

                // Build emitted message
                let message = EmittedMessage {
                    user_id: event.sender.clone(),
                    user_name: event.sender.clone(), // Simplified
                    content: body.clone(),
                    thread_id: room_id.clone(),
                    metadata_json,
                };

                if let Err(e) = channel_host::emit_message(&message) {
                    channel_host::log(
                        channel_host::LogLevel::Error,
                        &format!("Failed to emit message: {}", e),
                    );
                }
            }
        }
    }
}
    };

    // Read homeserver from config
    let homeserver = &config.homeserver;

    // Read sync token from workspace
    let sync_token = match workspace_read(format!("{}/{}", WORKSPACE_PREFIX, SYNC_TOKEN_PATH)) {
        Some(token) => Some(token),
        None => {
            log(
                log - level::info,
                "No sync token found, performing first poll",
            );
            // Call whoami to get user ID
            match fetch_user_info(homeserver, &config) {
                Ok(_) => None,
                Err(e) => {
                    log(
                        log - level::error,
                        format!("Failed to fetch user info: {}", e),
                    );
                    return AgentResponse::Err(format!("Failed to fetch user info: {}", e));
                }
            }
        }
    };

    // Build sync URL
    let url = build_sync_url(homeserver, sync_token.as_deref(), 30000);

    // Prepare HTTP request headers
    let headers = "{\"Authorization\":\"Bearer matrix_access_token\"}";

    // Make HTTP request
    let response = match http_request("GET", &url, headers, None, Some(35000)) {
        Ok(r) => r,
        Err(e) => {
            log(log - level::error, format!("HTTP request failed: {}", e));
            return AgentResponse::Err(format!("HTTP request failed: {}", e));
        }
    };

    // Check response status
    if response.status != 200 {
        log(
            log - level::error,
            format!("Sync request failed with status: {}", response.status),
        );
        return AgentResponse::Err(format!("Sync request failed: {}", response.status));
    }

    // Parse sync response
    let sync_response: SyncResponse = match serde_json::from_slice(&response.body) {
        Ok(r) => r,
        Err(e) => {
            log(
                log - level::error,
                format!("Failed to parse sync response: {}", e),
            );
            return AgentResponse::Err(format!("Invalid sync response: {}", e));
        }
    };

    // Persist sync token
    if let Err(e) = workspace_write(
        format!("{}/{}", WORKSPACE_PREFIX, SYNC_TOKEN_PATH),
        sync_response.next_batch.clone(),
    ) {
        log(
            log - level::error,
            format!("Failed to write sync token: {}", e),
        );
    }

    // Process messages
    let mut messages = vec![];

    for (room_id, joined_room) in &sync_response.rooms.joined {
        log(log - level::debug, format!("Processing room: {}", room_id));

        for event in &joined_room.timeline.events {
            // Only process m.room.message events with m.text content
            if let EventContent::Message {
                msgtype,
                body,
                formatted_body,
                ..
            } = &event.content
            {
                if msgtype != "m.text" {
                    continue;
                }

                // Skip own messages
                if let Some(own_id) = &config.user_id {
                    if event.sender == *own_id {
                        continue;
                    }
                }

                // Determine if DM
                let is_direct = is_dm_room(room_id);

                // Build message metadata
                let metadata = MatrixMessageMetadata {
                    room_id: room_id.clone(),
                    event_id: event.event_id.clone(),
                    sender: event.sender.clone(),
                    is_direct,
                    thread_root_event_id: None,
                    reply_to_event_id: None,
                };

                // Serialize metadata
                let metadata_json = match serde_json::to_string(&metadata) {
                    Ok(j) => j,
                    Err(e) => {
                        log(
                            log - level::error,
                            format!("Failed to serialize metadata: {}", e),
                        );
                        continue;
                    }
                };

                // Build emitted message
                let message = EmittedMessage {
                    user_id: event.sender.clone(),
                    user_name: event.sender.clone(), // Simplified
                    content: body.clone(),
                    thread_id: room_id.clone(),
                    metadata_json,
                };

                messages.push(message);
            }
        }
    }

    // Emit messages
    for msg in messages {
        if let Err(e) = channel_host::emit_message(msg) {
            log(log - level::error, format!("Failed to emit message: {}", e));
        }
    }

    AgentResponse::Ok(String::new())
}

/// Handle channel respond (outbound message).
fn on_respond(config_json: String, message_json: String) -> Result<(), String> {
    channel_host::log(
        channel_host::LogLevel::Debug,
        "Matrix channel responding",
    );

    // Parse config
    let config: MatrixConfig = match serde_json::from_str(&config_json) {
        Ok(c) => c,
        Err(e) => {
            channel_host::log(
                channel_host::LogLevel::Error,
                &format!("Failed to parse config: {}", e),
            );
            return Err(format!("Invalid config: {}", e));
        }
    };

    // Parse message metadata
    let metadata: MatrixMessageMetadata = match serde_json::from_str(&message_json) {
        Ok(m) => m,
        Err(e) => {
            channel_host::log(
                channel_host::LogLevel::Error,
                &format!("Failed to parse message metadata: {}", e),
            );
            return Err(format!("Invalid metadata: {}", e));
        }
    };

    // Generate transaction ID
    let txn_id = generate_txn_id();

    // Generate message body
    let body_json = serde_json::to_string(&MatrixSendMessageRequest {
        msgtype: "m.text".to_string(),
        body: message_json,
    })
    .unwrap();

    // Send message
    let url = format!(
        "{}/_matrix/client/v3/rooms/{}/send/m.room.message/{}",
        config.homeserver,
        metadata.room_id,
        txn_id
    );

    let headers = "{\"Authorization\":\"Bearer matrix_access_token\"}";

    let response = match channel_host::http_request(
        "PUT",
        &url,
        headers,
        None,
        Some(30000),
    ) {
        Ok(r) => r,
        Err(e) => {
            channel_host::log(
                channel_host::LogLevel::Error,
                &format!("Failed to send message: {}", e),
            );
            return Err(format!("Failed to send message: {}", e));
        }
    };

    if response.status != 200 {
        channel_host::log(
            channel_host::LogLevel::Error,
            &format!("Message send failed with status: {}", response.status),
        );
        return Err(format!("Message send failed: {}", response.status));
    }

    Ok(())
}
    };

    // Parse message metadata
    let metadata: MatrixMessageMetadata = match serde_json::from_str(&message_json) {
        Ok(m) => m,
        Err(e) => {
            log(
                log - level::error,
                format!("Failed to parse message metadata: {}", e),
            );
            return AgentResponse::Err(format!("Invalid metadata: {}", e));
        }
    };

    // Generate transaction ID
    let txn_id = generate_txn_id();

    // Generate message body
    let body_json = serde_json::to_string(&MatrixSendMessageRequest {
        msgtype: "m.text".to_string(),
        body: message_json,
    })
    .unwrap();

    // Send message
    let url = format!(
        "{}/_matrix/client/v3/rooms/{}/send/m.room.message/{}",
        config.homeserver, metadata.room_id, txn_id,
    );

    let headers = "{\"Authorization\":\"Bearer matrix_access_token\"}";

    let response = match http_request("PUT", &url, headers, None, Some(30000)) {
        Ok(r) => r,
        Err(e) => {
            log(log - level::error, format!("Failed to send message: {}", e));
            return AgentResponse::Err(format!("Failed to send message: {}", e));
        }
    };

    if response.status != 200 {
        log(
            log - level::error,
            format!("Message send failed with status: {}", response.status),
        );
        return AgentResponse::Err(format!("Message send failed: {}", response.status));
    }

    AgentResponse::Ok(String::new())
}

/// Handle channel status update (typing indicators).
fn on_status(config_json: String, update_json: String) -> Result<(), String> {
    channel_host::log(
        channel_host::LogLevel::Debug,
        "Matrix channel handling status update",
    );

    // Parse config
    let config: MatrixConfig = match serde_json::from_str(&config_json) {
        Ok(c) => c,
        Err(e) => {
            channel_host::log(
                channel_host::LogLevel::Error,
                &format!("Failed to parse config: {}", e),
            );
            return Err(format!("Invalid config: {}", e));
        }
    };

    // Parse status update
    let update: StatusUpdate = match serde_json::from_str(&update_json) {
        Ok(u) => u,
        Err(e) => {
            channel_host::log(
                channel_host::LogLevel::Error,
                &format!("Failed to parse status update: {}", e),
            );
            return Err(format!("Invalid status update: {}", e));
        }
    };

    // Get user ID and room ID from metadata
    let user_id = match &config.user_id {
        Some(id) => id,
        None => {
            channel_host::log(
                channel_host::LogLevel::Warn,
                "No user ID configured, cannot send typing indicator",
            );
            return Ok(());
        }
    };

    let room_id = match &update.metadata_json {
        Some(m) => {
            let metadata: MatrixMessageMetadata = match serde_json::from_str(m) {
                Ok(meta) => meta.room_id,
                Err(e) => {
                    channel_host::log(
                        channel_host::LogLevel::Error,
                        &format!("Failed to parse metadata: {}", e),
                    );
                    return Err(format!("Invalid metadata: {}", e));
                }
            };
            room_id
        }
        None => {
            channel_host::log(
                channel_host::LogLevel::Warn,
                "No metadata in status update, cannot determine room",
            );
            return Ok(());
        }
    };

    // Send typing indicator
    let typing_request = serde_json::to_string(&MatrixTypingRequest {
        typing: update.typing,
        timeout_ms: 30000,
    })
    .unwrap();

    let url = format!(
        "{}/_matrix/client/v3/rooms/{}/typing/{}",
        config.homeserver,
        room_id,
        user_id
    );

    let headers = "{\"Authorization\":\"Bearer matrix_access_token\"}";

    let response = match channel_host::http_request(
        "PUT",
        &url,
        headers,
        Some(typing_request.into_bytes(), 30000),
        None,
    ) {
        Ok(r) => r,
        Err(e) => {
            channel_host::log(
                channel_host::LogLevel::Error,
                &format!("Failed to send typing indicator: {}", e),
            );
            return Err(format!("Failed to send typing indicator: {}", e));
        }
    };

    if response.status != 200 {
        channel_host::log(
            channel_host::LogLevel::Error,
            &format!("Typing indicator send failed with status: {}", response.status),
        );
    }

    Ok(())
}
    };

    // Parse status update
    let update: StatusUpdate = match serde_json::from_str(&update_json) {
        Ok(u) => u,
        Err(e) => {
            log(
                log - level::error,
                format!("Failed to parse status update: {}", e),
            );
            return AgentResponse::Err(format!("Invalid status update: {}", e));
        }
    };

    // Get user ID and room ID from metadata
    let user_id = match &config.user_id {
        Some(id) => id,
        None => {
            log(
                log - level::warn,
                "No user ID configured, cannot send typing indicator",
            );
            return AgentResponse::Ok(String::new());
        }
    };

    let room_id = match &update.metadata_json {
        Some(m) => {
            let metadata: MatrixMessageMetadata = match serde_json::from_str(m) {
                Ok(meta) => meta.room_id,
                Err(e) => {
                    log(
                        log - level::error,
                        format!("Failed to parse metadata: {}", e),
                    );
                    return AgentResponse::Err(format!("Invalid metadata: {}", e));
                }
            };
            room_id
        }
        None => {
            log(
                log - level::warn,
                "No metadata in status update, cannot determine room",
            );
            return AgentResponse::Ok(String::new());
        }
    };

    // Send typing indicator
    let typing_request = serde_json::to_string(&MatrixTypingRequest {
        typing: update.typing,
        timeout_ms: 30000,
    })
    .unwrap();

    let url = format!(
        "{}/_matrix/client/v3/rooms/{}/typing/{}",
        config.homeserver, room_id, user_id,
    );

    let headers = "{\"Authorization\":\"Bearer matrix_access_token\"}";

    let response = match http_request(
        "PUT",
        &url,
        headers,
        Some(typing_request.into_bytes(), 30000),
        None,
    ) {
        Ok(r) => r,
        Err(e) => {
            log(
                log - level::error,
                format!("Failed to send typing indicator: {}", e),
            );
            return AgentResponse::Err(format!("Failed to send typing indicator: {}", e));
        }
    };

    if response.status != 200 {
        log(
            log - level::error,
            format!(
                "Typing indicator send failed with status: {}",
                response.status
            ),
        );
    }

    AgentResponse::Ok(String::new())
}

/// Handle channel shutdown.
fn on_shutdown(_config_json: String) {
    channel_host::log(channel_host::LogLevel::Info, "Matrix channel shutting down");
}

/// Handle HTTP request.
fn on_http_request(_config_json: String, _request: IncomingHttpRequest) -> OutgoingHttpResponse {
    // Matrix uses polling, not webhooks, but we still need to implement this callback
    channel_host::log(
        channel_host::LogLevel::Debug,
        &format!("HTTP request received: {} {}", "GET", "/_matrix/client/v3/sync"), // Simplified
    );
    OutgoingHttpResponse {
        status: 200,
        headers_json: "{\"Content-Type\":\"application/json\"}",
        body: b"{}".to_vec(),
    }
}
}

// ============================================================================
// Helper Functions
// ============================================================================

/// Fetch user info (whoami).
fn fetch_user_info(homeserver: &str, config: &MatrixConfig) -> Result<(), String> {
    // Call whoami endpoint
    let url = format!("{}/_matrix/client/v3/account/whoami", homeserver);

    let headers = "{\"Authorization\":\"Bearer matrix_access_token\"}";

    let response = channel_host::http_request(
        "GET",
        &url,
        headers,
        None,
        Some(30000),
    )?;

    if response.status != 200 {
        return Err(format!("Whoami request failed with status: {}", response.status));
    }

    // Parse whoami response
    let whoami: MatrixWhoamiResponse = match serde_json::from_slice(&response.body) {
        Ok(r) => r,
        Err(e) => return Err(format!("Failed to parse whoami response: {}", e)),
    };

    // Persist user ID
    let _ = channel_host::workspace_write(
        format!("{}/{}", WORKSPACE_PREFIX, USER_ID_PATH),
        &whoami.user_id,
    );

    // Fetch display name
    if let Err(e) = fetch_display_name(homeserver, config) {
        channel_host::log(
            channel_host::LogLevel::Warn,
            &format!("Failed to fetch display name: {}", e),
        );
    }

    Ok(())
}

/// Fetch display name.
fn fetch_display_name(homeserver: &str, config: &MatrixConfig) -> Result<(), String> {
    let user_id = match &config.user_id {
        Some(id) => id,
        None => return Ok(()),
    };

    let url = format!("{}/_matrix/client/v3/profile/{}/displayname", homeserver, user_id);

    let headers = "{\"Authorization\":\"Bearer matrix_access_token\"}";

    let response = channel_host::http_request(
        "GET",
        &url,
        headers,
        None,
        Some(30000),
    )?;

    if response.status != 200 {
        return Err(format!("Display name request failed with status: {}", response.status));
    }

    // Parse profile response
    let profile: MatrixProfileResponse = match serde_json::from_slice(&response.body) {
        Ok(r) => r,
        Err(e) => return Err(format!("Failed to parse profile response: {}", e)),
    };

    // Persist display name
    if let Some(display_name) = profile.displayname {
        let _ = channel_host::workspace_write(
            format!("{}/{}", WORKSPACE_PREFIX, DISPLAY_NAME_PATH),
            display_name,
        );
    }

    Ok(())
}

    // Parse whoami response
    let whoami: MatrixWhoamiResponse = match serde_json::from_slice(&response.body) {
        Ok(r) => r,
        Err(e) => return Err(format!("Failed to parse whoami response: {}", e)),
    };

    // Persist user ID
    if let Err(e) = workspace_write(
        format!("{}/{}", WORKSPACE_PREFIX, USER_ID_PATH),
        whoami.user_id,
    ) {
        log(
            log - level::error,
            format!("Failed to write user ID: {}", e),
        );
    }

    // Fetch display name
    if let Err(e) = fetch_display_name(homeserver, config) {
        log(
            log - level::warn,
            format!("Failed to fetch display name: {}", e),
        );
    }

    Ok(())
}

/// Fetch display name.
fn fetch_display_name(homeserver: &str, config: &MatrixConfig) -> Result<(), String> {
    let user_id = match &config.user_id {
        Some(id) => id,
        None => return Ok(()),
    };

    let url = format!(
        "{}/_matrix/client/v3/profile/{}/displayname",
        homeserver, user_id
    );

    let headers = "{\"Authorization\":\"Bearer matrix_access_token\"}";

    let response = http_request("GET", &url, headers, None, Some(30000))?;

    if response.status != 200 {
        return Err(format!(
            "Display name request failed with status: {}",
            response.status
        ));
    }

    // Parse profile response
    let profile: MatrixProfileResponse = match serde_json::from_slice(&response.body) {
        Ok(r) => r,
        Err(e) => return Err(format!("Failed to parse profile response: {}", e)),
    };

    // Persist display name
    if let Some(display_name) = profile.displayname {
        if let Err(e) = workspace_write(
            format!("{}/{}", WORKSPACE_PREFIX, DISPLAY_NAME_PATH),
            display_name,
        ) {
            log(
                log - level::error,
                format!("Failed to write display name: {}", e),
            );
        }
    }

    Ok(())
}

// ============================================================================
// Unit Tests
// ============================================================================

#[cfg(test)]
mod tests {
    use super::*;

    // Test MatrixConfig parsing
    #[test]
    fn test_matrix_config_parsing() {
        let config_json = r#"{
            "homeserver": "https://matrix.org",
            "dm_policy": "pairing",
            "allow_from": ["user1", "user2"],
            "respond_to_all_group_messages": true,
            "group_policy": "allowlist",
            "groups": {"room1": "Room 1"},
            "auto_join": "always",
            "auto_join_allowlist": ["room2"],
            "encryption": false
        }"#;

        let config: MatrixConfig = serde_json::from_str(config_json).unwrap();
        assert_eq!(config.homeserver, "https://matrix.org");
        assert_eq!(config.dm_policy, "pairing");
        assert_eq!(config.allow_from.len(), 2);
        assert!(config.respond_to_all_group_messages);
        assert_eq!(config.group_policy, "allowlist");
        assert_eq!(config.groups.get("room1"), Some(&"Room 1".to_string()));
        assert_eq!(config.auto_join, "always");
        assert_eq!(config.auto_join_allowlist.len(), 1);
        assert!(!config.encryption);
    }

    #[test]
    fn test_matrix_config_missing_homeserver() {
        let config_json = r#"{}"#;
        let result = serde_json::from_str::<MatrixConfig>(config_json);
        assert!(result.is_err());
    }

    // Test MatrixMessageMetadata serialization
    #[test]
    fn test_matrix_message_metadata_serialization() {
        let metadata = MatrixMessageMetadata {
            room_id: "!room:example.com".to_string(),
            event_id: "$event:example.com".to_string(),
            sender: "@user:example.com".to_string(),
            is_direct: true,
            thread_root_event_id: Some("$root:example.com".to_string()),
            reply_to_event_id: Some("$reply:example.com".to_string()),
        };

        let metadata_json = serde_json::to_string(&metadata).unwrap();
        let parsed: MatrixMessageMetadata = serde_json::from_str(&metadata_json).unwrap();

        assert_eq!(parsed.room_id, metadata.room_id);
        assert_eq!(parsed.event_id, metadata.event_id);
        assert_eq!(parsed.sender, metadata.sender);
        assert!(parsed.is_direct);
        assert_eq!(parsed.thread_root_event_id, metadata.thread_root_event_id);
        assert_eq!(parsed.reply_to_event_id, metadata.reply_to_event_id);
    }

    // Test clean_mention_text
    #[test]
    fn test_clean_mention_text_with_display_name() {
        let result = clean_mention_text("Hello @John Doe!", Some("John Doe"), "@user:server");
        assert_eq!(result, "Hello !");
    }

    #[test]
    fn test_clean_mention_text_with_user_id() {
        let result = clean_mention_text("Hello @user:server!", Some("John"), "@user:server");
        assert_eq!(result, "Hello !");
    }

    #[test]
    fn test_clean_mention_text_case_insensitive() {
        let result = clean_mention_text("Hello @john!", Some("John"), "@user:server");
        assert_eq!(result, "Hello !");
    }

    #[test]
    fn test_clean_mention_text_no_mention() {
        let result = clean_mention_text("Hello world!", None, "@user:server");
        assert_eq!(result, "Hello world!");
    }

    #[test]
    fn test_clean_mention_text_empty_after_strip() {
        let result = clean_mention_text("@user:server", Some("Bot"), "@user:server");
        assert_eq!(result, "");
    }

    // Test markdown_to_html
    #[test]
    fn test_markdown_to_html_bold() {
        let result = markdown_to_html("**bold** text").unwrap();
        assert!(result.contains("<strong>bold</strong>"));
    }

    #[test]
    fn test_markdown_to_html_italic() {
        let result = markdown_to_html("*italic* text").unwrap();
        assert!(result.contains("<em>italic</em>"));
    }

    #[test]
    fn test_markdown_to_html_code() {
        let result = markdown_to_html("`code` text").unwrap();
        assert!(result.contains("<code>code</code>"));
    }

    #[test]
    fn test_markdown_to_html_code_block() {
        let result = markdown_to_html("```block``` text").unwrap();
        assert!(result.contains("<pre><code>block</code></pre>"));
    }

    #[test]
    fn test_markdown_to_html_link() {
        let result = markdown_to_html("[link](https://example.com)").unwrap();
        assert!(result.contains("<a href=\"https://example.com\">link</a>"));
    }

    #[test]
    fn test_markdown_to_html_newlines() {
        let result = markdown_to_html("line1\nline2").unwrap();
        assert!(result.contains("<br>"));
    }

    #[test]
    fn test_markdown_to_html_plain_text() {
        let result = markdown_to_html("plain text");
        assert!(result.is_none());
    }

    // Test is_dm_room
    #[test]
    fn test_is_dm_room() {
        assert!(is_dm_room("!dm:example.com"));
    }

    // Test json_response
    #[test]
    fn test_json_response() {
        let result = json_response(r#"{"key":"value"}"#.to_string(), 200);
        assert_eq!(result.status, 200);
        assert!(result.headers_json.contains("Content-Type"));
        assert!(result.body.contains(b"key"));
    }

    // Test build_sync_url
    #[test]
    fn test_build_sync_url_with_token() {
        let url = build_sync_url("https://example.com", Some("token123"), 30000);
        assert!(url.contains("https://example.com"));
        assert!(url.contains("token123"));
        assert!(url.contains("timeout=30000"));
    }

    #[test]
    fn test_build_sync_url_without_token() {
        let url = build_sync_url("https://example.com", None, 30000);
        assert!(url.contains("https://example.com"));
        assert!(!url.contains("token"));
        assert!(url.contains("timeout=30000"));
    }

    // Test generate_txn_id
    #[test]
    fn test_generate_txn_id() {
        let txn_id = generate_txn_id();
        assert!(txn_id.contains("."));
        assert!(txn_id.len() > 10);
    }

    #[test]
    fn test_generate_txn_id_uniqueness() {
        let id1 = generate_txn_id();
        let id2 = generate_txn_id();
        assert_ne!(id1, id2);
    }
}

