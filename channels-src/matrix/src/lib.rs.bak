// Matrix Client-Server API types have fields reserved for future use
#![allow(dead_code)]

//! Matrix Client-Server API channel for IronClaw.
//!
//! This WASM component implements the channel interface for receiving and responding
//! to Matrix messages via the /sync endpoint with long-polling.
//!
//! # Features
//!
//! - Sync-based long-polling (Matrix /sync endpoint)
//! - Private chat (DM) support with pairing flow
//! - Group chat support with @mention gating
//! - Reply threading support (m.relates_to)
//! - Markdown-to-HTML formatted messages
//! - Typing indicators
//!
//! # Security
//!
//! - Access token is injected by host during HTTP requests
//! - WASM never sees raw credentials
//! - HTTP requests are rate-limited and filtered via capabilities

// Generate bindings from the WIT file
wit_bindgen::generate!({
    world: "sandboxed-channel",
    path: "../../wit/channel.wit",
});

use serde::{Deserialize, Serialize};

// Re-export generated types
use exports::near::agent::channel::{
    ChannelConfig, Guest, HttpEndpointConfig, IncomingHttpRequest, OutgoingHttpResponse,
    PollConfig, StatusUpdate,
};
use near::agent::channel_host::{self, EmittedMessage};

// ============================================================================
// Matrix API Types
// ============================================================================

/// Matrix message event content.
#[derive(Debug, Deserialize)]
#[serde(tag = "type")]
enum EventContent {
    /// Text message.
    #[serde(rename = "m.room.message")]
    Message {
        /// Message type (m.text, m.emote, etc.).
        #[serde(rename = "msgtype")]
        msgtype: String,
        /// Message body.
        body: String,
        /// Formatted body (HTML).
        #[serde(default)]
        formatted_body: Option<String>,
        /// Relations (thread, reply).
        #[serde(default)]
        relates_to: Option<Relations>,
    },
    /// Encrypted message.
    #[serde(rename = "m.room.encrypted")]
    Encrypted {
        /// Algorithm.
        algorithm: String,
        /// Ciphertext.
        ciphertext: String,
    },
    /// Room encryption state event.
    #[serde(rename = "m.room.encryption")]
    EncryptedState {
        /// Encryption algorithm.
        algorithm: String,
    },
    /// Unknown content type.
    #[serde(other)]
    Unknown,
}

/// Relations (thread, reply).
#[derive(Debug, Deserialize)]
struct Relations {
    /// Type of relation.
    #[serde(rename = "rel_type")]
    rel_type: Option<String>,
    /// In-reply-to event.
    #[serde(rename = "m.in_reply_to")]
    in_reply_to: Option<InReplyTo>,
}

/// In-reply-to event.
#[derive(Debug, Deserialize)]
struct InReplyTo {
    /// Event ID being replied to.
    event_id: Option<String>,
}

/// Matrix room timeline event.
#[derive(Debug, Deserialize)]
struct TimelineEvent {
    /// Unique event ID.
    event_id: String,
    /// Sender user ID.
    sender: String,
    /// Event content.
    content: EventContent,
    /// Timestamp in milliseconds.
    origin_server_ts: u64,
}

/// Matrix room summary.
#[derive(Debug, Deserialize)]
struct RoomSummary {
    /// Number of joined members.
    joined_member_count: u64,
}

/// Matrix joined room.
#[derive(Debug, Deserialize)]
struct JoinedRoom {
    /// Room ID.
    room_id: String,
    /// Timeline of events.
    timeline: Timeline,
    /// Room summary.
    #[serde(default)]
    summary: Option<RoomSummary>,
}

/// Matrix timeline.
#[derive(Debug, Deserialize)]
struct Timeline {
    /// Events in the timeline.
    #[serde(default)]
    events: Vec<TimelineEvent>,
}

/// Matrix account data entry.
#[derive(Debug, Deserialize)]
struct AccountData {
    /// Type of account data.
    #[serde(rename = "type")]
    account_data_type: String,
    /// Content.
    content: serde_json::Value,
}

/// Matrix account data.
#[derive(Debug, Deserialize)]
struct AccountDataEntry {
    /// Account data entries.
    #[serde(default)]
    events: Vec<AccountData>,
}

/// Matrix sync response.
#[derive(Debug, Deserialize)]
struct SyncResponse {
    /// Next batch token for incremental sync.
    next_batch: String,
    /// Room data.
    rooms: RoomsData,
}

/// Matrix rooms data.
#[derive(Debug, Deserialize)]
struct RoomsData {
    /// Joined rooms.
    joined: std::collections::HashMap<String, JoinedRoom>,
}

/// Matrix room message.
#[derive(Debug, Deserialize)]
struct MatrixRoomMessage {
    /// Room ID.
    room_id: String,
    /// Message ID.
    message_id: String,
    /// Sender user ID.
    sender: String,
    /// Message body.
    body: String,
    /// Display name of sender.
    display_name: Option<String>,
}

/// Matrix send response.
#[derive(Debug, Deserialize)]
struct MatrixSendResponse {
    /// Event ID.
    event_id: String,
}

/// Matrix whoami response.
#[derive(Debug, Deserialize)]
struct MatrixWhoamiResponse {
    /// User ID.
    user_id: String,
}

/// Matrix profile response.
#[derive(Debug, Deserialize)]
struct MatrixProfileResponse {
    /// Display name.
    displayname: Option<String>,
}

/// Matrix send message request.
#[derive(Debug, Serialize)]
struct MatrixSendMessageRequest {
    /// Message type.
    msgtype: String,
    /// Message body.
    body: String,
}

/// Matrix formatted message request.
#[derive(Debug, Serialize)]
struct MatrixFormattedMessageRequest {
    /// Message type.
    msgtype: String,
    /// Message body.
    body: String,
    /// Format type.
    format: String,
    /// Formatted body (HTML).
    formatted_body: String,
}

/// Matrix typing request.
#[derive(Debug, Serialize)]
struct MatrixTypingRequest {
    /// Typing status.
    typing: bool,
    /// Typing timeout in milliseconds.
    #[serde(rename = "timeout")]
    timeout_ms: u64,
}

// ============================================================================
// Channel Configuration
// ============================================================================

/// Metadata stored with emitted messages for response routing.
#[derive(Debug, Serialize, Deserialize)]
struct MatrixMessageMetadata {
    /// Room ID where the message was received.
    room_id: String,
    /// Event ID of the message.
    event_id: String,
    /// Sender user ID.
    sender: String,
    /// Whether this is a direct message.
    is_direct: bool,
    /// Thread root event ID (if threaded).
    #[serde(default)]
    thread_root_event_id: Option<String>,
    /// Reply to event ID (for replies).
    #[serde(default)]
    reply_to_event_id: Option<String>,
}

/// Matrix channel configuration.
#[derive(Debug, Deserialize, Serialize)]
struct MatrixConfig {
    /// Homeserver URL (required).
    homeserver: String,
    /// Bot user ID (optional, used for own message filtering).
    user_id: Option<String>,
    /// DM policy: "pairing", "allowlist", "open", or "disabled".
    #[serde(default)]
    dm_policy: String,
    /// Allowed senders for DMs (case-insensitive, "*" for all).
    #[serde(default)]
    allow_from: Vec<String>,
    /// Respond to all group messages (if false, only respond to @mentions).
    #[serde(default)]
    respond_to_all_group_messages: bool,
    /// Group policy: "allowlist", "open", or "disabled".
    #[serde(default)]
    group_policy: String,
    /// Room allowlist (map of room ID to display name).
    #[serde(default)]
    groups: std::collections::HashMap<String, String>,
    /// Auto-join policy: "always", "allowlist", or "off".
    #[serde(default)]
    auto_join: String,
    /// Auto-join allowlist.
    #[serde(default)]
    auto_join_allowlist: Vec<String>,
    /// Enable E2EE (optional).
    #[serde(default)]
    encryption: bool,
}

